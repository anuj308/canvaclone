# Copy this file to .env in server/ before running docker compose.

# Frontend URL(s) that can call the API gateway. Comma-separated.
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Google auth client id used by api-gateway auth middleware.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Runtime mode. Use production for server deploys and development for local testing.
NODE_ENV=production

# Shared MongoDB connection string used by backend services.
# Example for MongoDB Atlas:
# MONGO_URI=mongodb+srv://USER:PASSWORD@CLUSTER_URL/canvaclone?retryWrites=true&w=majority
MONGO_URI=

# Upload service integrations.
STABILITY_API_KEY=
cloud_name=
api_key=
api_secret=

# Optional API gateway overrides.
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000
